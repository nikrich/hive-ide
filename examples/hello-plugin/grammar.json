{
  "defaultToken": "",
  "keywords": ["smile", "happy", "joy", "sad", "angry"],
  "tokenizer": {
    "root": [
      [":\\)|:\\(|:D|:P", "string"],
      ["//.*$", "comment"],
      ["[0-9]+", "number"],
      ["[a-zA-Z_][a-zA-Z0-9_]*", {
        "cases": {
          "@keywords": "keyword",
          "@default": "identifier"
        }
      }]
    ]
  }
}
