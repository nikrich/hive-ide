{
  "name": "hive-ide",
  "private": true,
  "version": "0.1.0",
  "description": "Hive IDE — a multi-agent code editor desktop app. Built by hungry-ghost-hive v2.",
  "main": "out/main/index.js",
  "author": "nikrich",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -b --noEmit && electron-vite build",
    "build:mac": "npm run build && electron-builder --mac --config",
    "build:win": "npm run build && electron-builder --win --config",
    "build:linux": "npm run build && electron-builder --linux --config",
    "preview": "electron-vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "postinstall": "electron-rebuild --only node-pty"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/adm-zip": "^0.5.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.17",
    "chokidar": "^4.0.3",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.460.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semver": "^7.8.1",
    "tar": "^7.5.16",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "yaml": "^2.9.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/semver": "^7.7.1",
    "@types/tar": "^6.1.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "mock-fs": "^5.5.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "dev.nikrich.hive-ide",
    "productName": "Hive IDE",
    "directories": {
      "buildResources": "build",
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
